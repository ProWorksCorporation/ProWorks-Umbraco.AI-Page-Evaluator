@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Extensions
@using Umbraco.Cms.Core.Models.PublishedContent
@{
    var metaTitle = ViewBag.MetaTitle as string ?? Model?.Name ?? "Home";
    var metaDescription = ViewBag.MetaDescription as string ?? "";
    var ogImageUrl = ViewBag.OgImageUrl as string ?? "";

    var home = Umbraco.ContentAtRoot().FirstOrDefault();
    var navItems = home?.Children.Where(x => x.IsVisible()) ?? Enumerable.Empty<IPublishedContent>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@metaTitle</title>
    @if (!string.IsNullOrWhiteSpace(metaDescription))
    {
        <meta name="description" content="@metaDescription" />
    }
    @if (!string.IsNullOrWhiteSpace(ogImageUrl))
    {
        <meta property="og:image" content="@ogImageUrl" />
    }
    <meta property="og:title" content="@metaTitle" />
    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-white text-slate-800 font-sans antialiased">

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white shadow-sm border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-2 font-bold text-xl text-indigo-600 hover:text-indigo-700 transition-colors">
                    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    </svg>
                    <span>@(home?.Name ?? "My Site")</span>
                </a>

                <!-- Desktop nav links -->
                <div class="hidden md:flex items-center gap-1">
                    @foreach (var item in navItems)
                    {
                        <a href="@item.Url()"
                           class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors">
                            @item.Name
                        </a>
                    }
                </div>

                <!-- Mobile hamburger -->
                <button id="nav-toggle" class="md:hidden p-2 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
            </div>

            <!-- Mobile menu -->
            <div id="mobile-menu" class="hidden md:hidden pb-4">
                @foreach (var item in navItems)
                {
                    <a href="@item.Url()"
                       class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors">
                        @item.Name
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- Page content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-slate-800 text-slate-300 mt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Brand -->
                <div>
                    <div class="font-bold text-xl text-white mb-2">@(home?.Name ?? "My Site")</div>
                    <p class="text-sm text-slate-400 max-w-xs">
                        A test site for the ProWorks Umbraco AI Page Evaluator.
                    </p>
                </div>
                <!-- Nav links -->
                <div>
                    <div class="font-semibold text-white text-sm mb-3 uppercase tracking-wider">Pages</div>
                    <ul class="space-y-2">
                        @foreach (var item in navItems)
                        {
                            <li>
                                <a href="@item.Url()" class="text-sm text-slate-400 hover:text-white transition-colors">
                                    @item.Name
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
            <div class="border-t border-slate-700 mt-10 pt-6 text-xs text-slate-500 text-center">
                &copy; @DateTime.Now.Year <a href="https://www.proworks.com" class="hover:text-slate-300 transition-colors">ProWorks Corporation</a>. Built with Umbraco &amp; Tailwind CSS.
            </div>
        </div>
    </footer>

    <script>
        document.getElementById('nav-toggle').addEventListener('click', function () {
            var menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        });
    </script>
</body>
</html>
