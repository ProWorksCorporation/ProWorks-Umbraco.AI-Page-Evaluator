  <Properties>
    <ctaBody>
      <Value><![CDATA[MIT license. No new AI subscription required. Works with your existing Umbraco.AI profile (Anthropic or OpenAI). Requires Umbraco 17.2 and Umbraco.AI 1.8.]]></Value>
    </ctaBody>
