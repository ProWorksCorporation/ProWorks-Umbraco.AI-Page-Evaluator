    <ctaHeading>
      <Value><![CDATA[Install in 5 minutes - it's free]]></Value>
    </ctaHeading>
    <headerImage>
      <Value><![CDATA[[
  {
    "key": "9862e13d-de07-43cd-9f57-b281b72129d4",
