    <ctaHeading>
      <Value><![CDATA[Add AI to your Umbraco site]]></Value>
    </ctaHeading>
    <headerImage>
      <Value><![CDATA[[
  {
    "key": "9862e13d-de07-43cd-9f57-b281b72129d4",
    "mediaKey": "cce909b0-76e5-4c49-952c-35b1eb9de2f9",
