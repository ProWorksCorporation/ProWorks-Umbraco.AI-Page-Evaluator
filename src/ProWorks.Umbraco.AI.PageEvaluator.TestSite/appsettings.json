{
  "$schema": "appsettings-schema.json",
  "uSync": {
    "Sets": {
      "Default": {
        "Handlers": {
          "ContentHandler": {
            "Enabled": true
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "e53cbfd1-170f-4abc-adfe-0a14c253f479"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  },
  "ProWorksPageEvaluator": {
    "RateLimitSeconds": 10
  }
}
